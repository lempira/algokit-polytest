{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "lib": ["ES2022", "dom"],
    "types": ["node"],
    "outDir": "../dist/poller",
    "declaration": true,
    "importHelpers": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "examples/**/*.ts",
    "schemas/**/*.ts",
    "vitest.config.ts"
  ]
}
